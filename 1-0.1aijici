    <!-- 1. HTML 修改(直接放在 <body> 内的最外层) -->
    <div id="settings-modal" class="fixed inset-0 z-[200] flex items-center justify-center p-4 bg-black/40 backdrop-blur-sm hidden opacity-0 transition-all duration-300">
        <div class="bg-white rounded-[24px] w-full max-w-[420px] shadow-2xl border border-gray-100 overflow-hidden transform scale-95 transition-all duration-300">
            <div class="px-6 py-5 border-b border-gray-100 flex justify-between items-center bg-gray-50/50">
                <h3 class="font-extrabold text-[18px] text-gray-800">个性化关卡参数</h3>
                <button onclick="closeSettingsModal()" class="w-8 h-8 rounded-full hover:bg-gray-200 flex items-center justify-center text-gray-400 hover:text-gray-600 transition-colors focus:outline-none">
                    <i class="ph-bold ph-x text-[18px]"></i>
                </button>
            </div>
            <div class="p-6 flex flex-col gap-5">
                <div class="flex items-center justify-between bg-blue-50/50 p-4 rounded-[16px] border border-blue-100/50">
                    <div class="flex flex-col">
                        <span class="font-extrabold text-[15px] text-gray-800">使用个性化配置</span>
                        <span class="text-[12px] font-bold text-gray-400 mt-0.5" id="settings-status-text">当前：跟随班级默认进度</span>
                    </div>
                    <button id="toggle-switch" onclick="toggleSettingsActive()" class="w-[46px] h-[24px] bg-slate-200 rounded-full p-0.5 transition-colors duration-300 relative focus:outline-none cursor-pointer shadow-[inset_0_1px_2px_rgba(0,0,0,0.1)] shrink-0">
                        <div class="w-[20px] h-[20px] bg-white rounded-full shadow-sm transition-transform duration-300 transform translate-x-0 flex items-center justify-center"></div>
                    </button>
                </div>

                <div id="settings-fields" class="flex flex-col gap-4 opacity-50 pointer-events-none transition-all duration-300">
                    <div class="flex justify-between items-center group">
                        <div class="flex flex-col">
                            <span class="font-bold text-[14px] text-gray-700">单关词汇量</span>
                            <span class="text-[11px] font-medium text-gray-400">建议 10~200</span>
                        </div>
                        <div class="flex items-center bg-gray-50 border border-gray-200 rounded-[12px] px-2 py-1 shadow-[inset_0_1px_2px_rgba(0,0,0,0.02)] focus-within:border-blue-400 focus-within:bg-white transition-colors">
                            <input type="number" id="input-words-per-gate" min="1" max="200" value="50" oninput="window.validateThreshold()" class="w-14 text-center bg-transparent text-[14px] font-black outline-none text-gray-800">
                            <span class="text-[12px] text-gray-400 font-bold pr-1">词</span>
                        </div>
                    </div>
                    <div class="flex justify-between items-center group">
                        <div class="flex flex-col">
                            <span class="font-bold text-[14px] text-gray-700">单关循环组数</span>
                            <span class="text-[11px] font-medium text-gray-400">分组学习降低记忆负担</span>
                        </div>
                        <div class="flex items-center bg-gray-50 border border-gray-200 rounded-[12px] px-2 py-1 shadow-[inset_0_1px_2px_rgba(0,0,0,0.02)] focus-within:border-blue-400 focus-within:bg-white transition-colors">
                            <input type="number" id="input-groups-per-gate" min="1" max="30" value="3" class="w-14 text-center bg-transparent text-[14px] font-black outline-none text-gray-800">
                            <span class="text-[12px] text-gray-400 font-bold pr-1">组</span>
                        </div>
                    </div>
                    <div class="flex justify-between items-start group">
                        <div class="flex flex-col pt-1">
                            <span class="font-bold text-[14px] text-gray-700">最低通关要求</span>
                            <span id="threshold-limit-desc" class="text-[11px] font-medium text-gray-400">掌握词数不能低于单关一半</span>
                            <span id="threshold-warning" class="text-[11px] font-bold text-red-500 hidden mt-0.5"><i class="ph-bold ph-warning-circle"></i> 不得低于标准</span>
                        </div>
                        <div class="flex items-center bg-gray-50 border border-gray-200 rounded-[12px] px-2 py-1 shadow-[inset_0_1px_2px_rgba(0,0,0,0.02)] focus-within:border-blue-400 focus-within:bg-white transition-colors" id="threshold-input-wrapper">
                            <input type="number" id="input-threshold" value="20" oninput="window.validateThreshold()" class="w-14 text-center bg-transparent text-[14px] font-black outline-none text-gray-800 transition-colors">
                            <span class="text-[12px] text-gray-400 font-bold pr-1">词</span>
                        </div>
                    </div>
                    <div class="h-px bg-gray-100 w-full my-1"></div>
                    <div class="flex justify-between items-center group">
                        <span class="font-bold text-[14px] text-gray-700">发音停顿间隔</span>
                        <div class="flex items-center bg-gray-50 border border-gray-200 rounded-[12px] px-2 py-1 shadow-[inset_0_1px_2px_rgba(0,0,0,0.02)] focus-within:border-blue-400 focus-within:bg-white transition-colors">
                            <input type="number" id="input-audio-interval" step="0.1" min="0" max="30" value="0.00" class="w-14 text-center bg-transparent text-[14px] font-black outline-none text-gray-800">
                            <span class="text-[12px] text-gray-400 font-bold pr-1">秒</span>
                        </div>
                    </div>
                    <div class="flex justify-between items-center group">
                        <span class="font-bold text-[14px] text-gray-700">单词切换间隔</span>
                        <div class="flex items-center bg-gray-50 border border-gray-200 rounded-[12px] px-2 py-1 shadow-[inset_0_1px_2px_rgba(0,0,0,0.02)] focus-within:border-blue-400 focus-within:bg-white transition-colors">
                            <input type="number" id="input-word-interval" step="0.1" min="1" max="30" value="1.00" class="w-14 text-center bg-transparent text-[14px] font-black outline-none text-gray-800">
                            <span class="text-[12px] text-gray-400 font-bold pr-1">秒</span>
                        </div>
                    </div>
                </div>

                <div class="flex justify-center gap-3 mt-2 pt-5 border-t border-gray-100">
                    <button onclick="closeSettingsModal()" class="flex-1 py-3 bg-white border border-gray-200 hover:bg-gray-50 text-gray-600 font-extrabold text-[14px] rounded-[14px] transition-all active:scale-95 shadow-sm">取消更改</button>
                    <button id="btn-submit-settings" onclick="saveSettings()" class="flex-1 py-3 bg-[#1F5FFF] hover:bg-[#004ce6] text-white font-extrabold text-[14px] rounded-[14px] transition-all active:scale-95 shadow-[0_4px_12px_rgba(31,95,255,0.25)] flex items-center justify-center gap-1.5">应用设置</button>
                </div>
            </div>
        </div>
    </div>

    <script>
        (function() {
            var state = {
                assignedTasks: [
                    { id: 101, title: "必修一 Unit 1 核心词汇", count: 45, target: 1, current: 45, lastDone: new Date().toDateString() },
                    { id: 102, title: "单元音单音节（新）", count: 30, target: 1, current: 15, lastDone: null },
                    { id: 103, title: "必修一 Unit 2 重点词组", count: 25, target: 1, current: 0, lastDone: null },
                    { id: 104, title: "模块三 综合复习卷一", count: 60, target: 1, current: 12, lastDone: null },
                    { id: 105, title: "高考高频词 冲刺一", count: 50, target: 1, current: 5, lastDone: null },
                    { id: 106, title: "双元音发音特训", count: 40, target: 1, current: 0, lastDone: null },
                    { id: 107, title: "必修一 Unit 3 拓展词汇", count: 35, target: 1, current: 0, lastDone: null },
                    { id: 108, title: "不规则动词变化表上", count: 55, target: 1, current: 0, lastDone: null }
                ],
                stats: { 
                    totalTarget: 3000, 
                    totalLearned: 1730, 
                    unlearnedNew: 1270, 
                    known: 1280, 
                    read: 1200, 
                    memo: 1100, 
                    dict: 1050, 
                    unknown: 450, 
                    unlearned: 1270
                }
            };

            function safeSetTextByClass(className, value) {
                document.querySelectorAll('.' + className).forEach(el => el.innerText = value);
            }

            function renderDashboardUI() {
                var total = state.stats.totalTarget;
                var known = state.stats.known;
                var unknown = state.stats.unknown;
                var unlearned = state.stats.unlearned;
                var learnedSum = known + unknown;

                var percent = Math.round((learnedSum / total) * 100) || 0;
                
                safeSetTextByClass('dash-goal-text', total);
                safeSetTextByClass('dash-learned-text', learnedSum);
                safeSetTextByClass('dash-percent-text', percent + '%');
                document.querySelectorAll('.dash-progress-ring').forEach(el => {
                    el.style.strokeDashoffset = 150.8 - (percent / 100) * 150.8;
                });
                document.querySelectorAll('.dash-progress-ring-lg').forEach(el => {
                    el.style.strokeDashoffset = 175.9 - (percent / 100) * 175.9;
                });
                
                safeSetTextByClass('dash-known-text', known);
                safeSetTextByClass('dash-newwords-text', state.stats.unknown);
                safeSetTextByClass('dash-unknown-text', unlearned);
                safeSetTextByClass('dash-mic-text', state.stats.read);
                safeSetTextByClass('dash-listen-text', state.stats.memo);
                safeSetTextByClass('dash-dictate-text', state.stats.dict);
                
                var today = new Date().toDateString();
                
                document.querySelectorAll('.tasks-container').forEach(taskContainer => {
                    var mainTaskBadge = taskContainer.parentElement.querySelector('.task-badge-count');
                    var noTaskBox = taskContainer.parentElement.querySelector('.no-task-box');
                    
                    if (state.assignedTasks.length > 0) {
                        taskContainer.classList.remove('hidden'); 
                        if(noTaskBox) noTaskBox.classList.add('hidden'); 
                        
                        if (mainTaskBadge) mainTaskBadge.innerText = state.assignedTasks.length;
                        
                        // 生成带内部网格线的表格，加高行高、去最外侧垂直线、进入按钮改圆+箭头
                        let html = `
                            <div class="w-full border-t border-gray-200 overflow-hidden bg-white mt-1">
                                <table class="w-full text-left border-collapse" style="table-layout: fixed;">
                                    <thead class="bg-gray-50/80 text-[12px] font-extrabold text-gray-500 tracking-wider">
                                        <tr>
                                            <th class="w-[50px] py-3 text-center border-b border-r border-gray-200">序号</th>
                                            <th class="py-3 pl-4 border-b border-r border-gray-200 truncate">任务名称</th>
                                            <th class="w-[60px] py-3 text-center border-b border-r border-gray-200">词数</th>
                                            <th class="w-[80px] py-3 text-center border-b border-r border-gray-200">进度</th>
                                            <th class="w-[60px] py-3 text-center border-b border-gray-200">操作</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                        `;
                        
                        // 生成列表行
                        state.assignedTasks.forEach((task, index) => {
                            var isDoneToday = task.lastDone === today;
                            var numStr = (index + 1).toString().padStart(2, '0');
                            
                            var trClass = isDoneToday ? 'bg-gray-50/40' : 'hover:bg-blue-50/30 transition-colors cursor-pointer group';
                            var titleColor = isDoneToday ? 'text-gray-400' : 'text-gray-700 group-hover:text-blue-700';
                            var progressColor = isDoneToday ? 'text-emerald-500' : 'text-gray-800';
                            
                            var btnHtml = isDoneToday 
                                ? `<button class="w-8 h-8 rounded-full bg-gray-100 text-gray-400 flex items-center justify-center cursor-not-allowed shadow-inner transition-all mx-auto" title="已完成">
                                       <i class="ph-bold ph-check text-[15px]"></i>
                                   </button>` 
                                : `<button class="w-8 h-8 rounded-full bg-blue-50 text-blue-600 group-hover:bg-blue-500 group-hover:text-white flex items-center justify-center transition-all shadow-sm mx-auto active:scale-95" onclick="window.showToast('进入任务: ${task.title}')" title="进入任务">
                                       <i class="ph-bold ph-arrow-right text-[15px]"></i>
                                   </button>`;

                            html += `
                                <tr class="${trClass}">
                                    <td class="py-3.5 text-center border-b border-r border-gray-200 text-[13px] font-mono font-bold text-gray-400">${numStr}</td>
                                    <td class="py-3.5 pl-4 border-b border-r border-gray-200 text-[14px] font-bold ${titleColor} truncate transition-colors" title="${task.title}">${task.title}</td>
                                    <td class="py-3.5 text-center border-b border-r border-gray-200 text-[13px] font-mono font-medium text-gray-500">${task.count}</td>
                                    <td class="py-3.5 text-center border-b border-r border-gray-200 text-[14px] font-mono font-black ${progressColor}">
                                        ${task.current}/${task.count}
                                    </td>
                                    <td class="py-3.5 text-center border-b border-gray-200">
                                        ${btnHtml}
                                    </td>
                                </tr>
                            `;
                        });
                        html += `
                                    </tbody>
                                </table>
                            </div>
                        `;
                        taskContainer.innerHTML = html;
                    } else { 
                        taskContainer.classList.add('hidden'); 
                        if(noTaskBox) noTaskBox.classList.remove('hidden'); 
                        if (mainTaskBadge) mainTaskBadge.innerText = '0';
                    }
                });
            }

            // 初始化渲染
            renderDashboardUI();
            
            // ===============================================
            // 2. 对应的 JavaScript 逻辑 (补充到 <script> 标签内)
            // ===============================================

            // 状态容器（如需独立运行请确保有此状态对象）
            var appState = {
                isPersonalizedSettings: false,
                settings: {
                    wordsPerGate: 50,
                    groupsPerGate: 3,
                    threshold: 20,
                    audioInterval: 0.00,
                    wordInterval: 1.00
                }
            };

            function safeSetValue(id, value) {
                var el = document.getElementById(id);
                if (el) el.value = value;
            }

            // ===============================================
            // 右上角弹窗：个性化参数设置逻辑
            // ===============================================
            window.toggleSettingsActive = function() {
                appState.isPersonalizedSettings = !appState.isPersonalizedSettings;
                setToggleSwitchState(appState.isPersonalizedSettings);
                window.validateThreshold();
            };

            function setToggleSwitchState(isActive) {
                var switchBtn = document.getElementById('toggle-switch');
                var fieldsWrapper = document.getElementById('settings-fields');
                var labelText = document.getElementById('settings-status-text');
                if(!switchBtn || !fieldsWrapper) return;
                
                var switchThumb = switchBtn.querySelector('div');
                if (isActive) {
                    switchBtn.classList.replace('bg-slate-200', 'bg-blue-500');
                    if(switchThumb) switchThumb.classList.replace('translate-x-0', 'translate-x-5');
                    if(labelText) labelText.innerText = "当前：使用个性化参数";
                    fieldsWrapper.classList.remove('opacity-50', 'pointer-events-none');
                } else {
                    switchBtn.classList.replace('bg-blue-500', 'bg-slate-200');
                    if(switchThumb) switchThumb.classList.replace('translate-x-5', 'translate-x-0');
                    if(labelText) labelText.innerText = "当前：跟随班级默认进度";
                    fieldsWrapper.classList.add('opacity-50', 'pointer-events-none');
                }
            }

            window.validateThreshold = function() {
                var warn = document.getElementById('threshold-warning');
                var input = document.getElementById('input-threshold');
                var wrapper = document.getElementById('threshold-input-wrapper');
                var btn = document.getElementById('btn-submit-settings');
                var desc = document.getElementById('threshold-limit-desc');

                if (!appState.isPersonalizedSettings) {
                    if(warn) warn.classList.add('hidden');
                    if(desc) desc.classList.remove('hidden');
                    if(wrapper) {
                        wrapper.classList.remove('border-red-400', 'bg-red-50');
                        wrapper.classList.add('bg-gray-50');
                    }
                    if(input) input.classList.remove('text-red-600');
                    if(btn) {
                        btn.disabled = false;
                        btn.classList.remove('opacity-40', 'pointer-events-none');
                    }
                    return;
                }
                var wordsEl = document.getElementById('input-words-per-gate');
                var threshEl = document.getElementById('input-threshold');
                var wordsVal = wordsEl ? (parseInt(wordsEl.value) || 0) : 0;
                var thresholdVal = threshEl ? (parseInt(threshEl.value) || 0) : 0;
                var minAllowed = Math.ceil(wordsVal / 2);

                if (thresholdVal < minAllowed) {
                    if(warn) warn.classList.remove('hidden');
                    if(desc) desc.classList.add('hidden');
                    if(wrapper) {
                        wrapper.classList.add('border-red-400', 'bg-red-50');
                        wrapper.classList.remove('bg-gray-50');
                    }
                    if(input) input.classList.add('text-red-600');
                    if(btn) {
                        btn.disabled = true;
                        btn.classList.add('opacity-40', 'pointer-events-none');
                    }
                } else {
                    if(warn) warn.classList.add('hidden');
                    if(desc) desc.classList.remove('hidden');
                    if(wrapper) {
                        wrapper.classList.remove('border-red-400', 'bg-red-50');
                        wrapper.classList.add('bg-gray-50');
                    }
                    if(input) input.classList.remove('text-red-600');
                    if(btn) {
                        btn.disabled = false;
                        btn.classList.remove('opacity-40', 'pointer-events-none');
                    }
                }
            };

            window.openSettingsModal = function() {
                var modal = document.getElementById('settings-modal');
                if (modal) {
                    modal.classList.remove('hidden');
                    setTimeout(() => {
                        modal.classList.remove('opacity-0');
                        var inner = modal.querySelector('.transform');
                        if (inner) inner.classList.remove('scale-95');
                    }, 50);
                }
                safeSetValue('input-words-per-gate', appState.settings.wordsPerGate);
                safeSetValue('input-groups-per-gate', appState.settings.groupsPerGate);
                safeSetValue('input-threshold', appState.settings.threshold);
                safeSetValue('input-audio-interval', appState.settings.audioInterval.toFixed(2));
                safeSetValue('input-word-interval', appState.settings.wordInterval.toFixed(2));
                setToggleSwitchState(appState.isPersonalizedSettings);
                window.validateThreshold();
            };

            window.closeSettingsModal = function() {
                var modal = document.getElementById('settings-modal');
                if (modal) {
                    modal.classList.add('opacity-0');
                    var inner = modal.querySelector('.transform');
                    if (inner) inner.classList.add('scale-95');
                    setTimeout(() => { modal.classList.add('hidden'); }, 300);
                }
            };

            window.saveSettings = function() {
                if (appState.isPersonalizedSettings) {
                    var valWords = document.getElementById('input-words-per-gate');
                    var valGroups = document.getElementById('input-groups-per-gate');
                    var valThresh = document.getElementById('input-threshold');
                    var valAudio = document.getElementById('input-audio-interval');
                    var valWordInt = document.getElementById('input-word-interval');

                    appState.settings.wordsPerGate = valWords ? parseInt(valWords.value) : 50;
                    appState.settings.groupsPerGate = valGroups ? parseInt(valGroups.value) : 3;
                    appState.settings.threshold = valThresh ? parseInt(valThresh.value) : 20;
                    appState.settings.audioInterval = valAudio ? parseFloat(valAudio.value) : 0;
                    appState.settings.wordInterval = valWordInt ? parseFloat(valWordInt.value) : 1;
                    
                    if(window.showToast) window.showToast('个性化配置已成功应用！', 'success');
                } else {
                    if(window.showToast) window.showToast('已回滚至默认全局配置！', 'info');
                }
                window.closeSettingsModal();
            };

        })();
    </script>
</body>
</html>
