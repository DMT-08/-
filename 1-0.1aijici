<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>英语单词 - 班级学习大盘</title>

    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/@phosphor-icons/web@2.0.3"></script>

    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');

        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background: linear-gradient(135deg, #EFF6FF 0%, #DFE7FF 100%);
            background-attachment: fixed;
            color: #1f2937;
            overflow-x: hidden;
            overscroll-behavior-y: none;
        }

        .shadow-premium {
            box-shadow: 0 4px 20px -4px rgba(0, 0, 0, 0.03), 0 2px 8px -2px rgba(0, 0, 0, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.9);
        }

        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

        .rank-crown-1 { color: #F59E0B; text-shadow: 0 2px 4px rgba(245, 158, 11, 0.3); } 
        .rank-crown-2 { color: #94A3B8; text-shadow: 0 2px 4px rgba(148, 163, 184, 0.3); } 
        .rank-crown-3 { color: #B45309; text-shadow: 0 2px 4px rgba(180, 83, 9, 0.3); } 

        /* 优化后的均分 Grid 布局，完美适配 1300px 尺寸平板 */
        .rank-grid {
            display: grid;
            /* 排名和姓名固定合理宽度，其余列弹性均分 */
            grid-template-columns: 40px 60px 1fr 1fr 1fr 1fr 1.1fr 1.1fr;
            gap: 4px;
            width: 100%; 
            align-items: center; /* 垂直居中 */
        }

        /* 强制所有网格内容水平居中，让数据列间距在视觉上绝对均匀 */
        .rank-grid > div {
            text-align: center !important;
            justify-content: center !important;
        }
    </style>
</head>
<body class="flex flex-col h-screen relative">

    <!-- 全局状态 Toast 容器 -->
    <div id="toast-container" class="fixed top-5 left-1/2 transform -translate-x-1/2 z-[150] flex flex-col gap-2 pointer-events-none"></div>

    <!-- ========================================== -->
    <!-- 独立视图：【班级学习大盘】 -->
    <!-- ========================================== -->
    <div id="view-ai-dashboard" class="view-section flex flex-col h-screen w-full shrink-0">
        
        <header class="flex justify-between items-center w-full max-w-[1300px] mx-auto p-4 md:p-5 shrink-0">
            <div class="flex items-center gap-4">
                <button class="w-10 h-10 bg-white rounded-full flex items-center justify-center shadow-premium text-gray-600 hover:bg-gray-50 transition-colors cursor-pointer">
                    <i class="ph-bold ph-caret-left text-[22px] -ml-0.5"></i>
                </button>
                <h1 class="text-[28px] md:text-[32px] font-extrabold text-gray-900 tracking-tight leading-none">英语单词</h1>
            </div>
            
            <div class="flex items-center gap-3 md:gap-4">
                <div class="flex items-center bg-white px-3 md:px-4 py-2 rounded-[12px] shadow-sm border border-gray-100">
                    <div class="w-7 h-7 bg-blue-100 rounded-full flex items-center justify-center text-blue-600 mr-2 shrink-0">
                        <i class="ph-bold ph-user text-[14px]"></i>
                    </div>
                    <div class="text-[13px] font-bold text-gray-500 hidden sm:block truncate max-w-[150px]">
                        庞胜材 <i class="ph-bold ph-caret-right text-[10px] mx-0.5"></i> <span class="text-gray-900">陈鑫朵</span>
                    </div>
                    <div class="text-[14px] font-extrabold text-gray-900 sm:hidden">陈鑫朵</div>
                </div>
                
                <!-- 新增：设置按钮 -->
                <button onclick="window.openSettingsModal()" class="w-11 h-11 bg-white rounded-[14px] flex items-center justify-center shadow-premium text-slate-500 hover:text-blue-500 hover:bg-blue-50 transition-all cursor-pointer shrink-0 active:scale-95" title="设置">
                    <i class="ph-fill ph-gear text-[24px]"></i>
                </button>
            </div>
        </header>

        <main class="flex-1 w-full max-w-[1300px] mx-auto px-4 md:px-5 pb-6 overflow-hidden min-h-0">
            <div class="flex flex-col lg:flex-row gap-5 md:gap-6 h-full">
                
                <!-- 左半屏：统一排行榜 -->
                <div class="flex-1 lg:w-1/2 bg-white rounded-[24px] shadow-premium flex flex-col overflow-hidden relative border border-gray-100 h-[450px] lg:h-full">
                    <div class="px-5 py-4 border-b border-gray-100 bg-gray-50/50 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-3 shrink-0">
                        <div class="flex items-center flex-wrap gap-2">
                            <div class="w-8 h-8 rounded-[10px] bg-yellow-100 text-yellow-600 flex items-center justify-center shadow-sm border border-yellow-200/50">
                                <i class="ph-fill ph-trophy text-[16px]"></i>
                            </div>
                            <h3 class="font-extrabold text-[16px] text-gray-800">班级排行</h3>
                            
                            <!-- 多班级 Tags -->
                            <div class="flex items-center bg-gray-200/50 p-1 rounded-[10px] ml-1">
                                <button class="px-3 py-1 bg-white shadow-sm text-gray-800 text-[12px] font-bold rounded-[8px]">英语实验1班</button>
                                <button class="px-3 py-1 text-gray-500 hover:text-gray-700 text-[12px] font-bold rounded-[8px] transition-colors">高二(3)班</button>
                            </div>
                        </div>
                        <div class="text-[11px] font-bold text-gray-400 bg-white px-3 py-1.5 rounded-[8px] shadow-sm border border-gray-100 whitespace-nowrap self-start sm:self-auto">
                            排位基准: <span class="text-green-600">通过数</span>
                        </div>
                    </div>
                    
                    <div class="flex-1 overflow-x-auto hide-scrollbar overflow-y-auto relative bg-white">
                        <div class="w-full pb-[68px]">
                            <!-- 表头 -->
                            <div class="rank-grid px-4 py-3 bg-white/95 backdrop-blur-sm border-b border-gray-100 text-[11px] font-extrabold text-gray-400 sticky top-0 z-20">
                                <div class="text-center">排名</div>
                                <div class="text-center">姓名</div>
                                <div class="text-right">总词库</div>
                                <div class="text-right text-gray-600">通过</div>
                                <div class="text-right">未通过</div>
                                <div class="text-right">未学</div>
                                <div class="text-right">昨日增加</div>
                                <div class="text-right pr-1">今天增加</div>
                            </div>
                            <!-- 列表内容 -->
                            <div class="flex flex-col relative z-0">
                                <div class="rank-grid px-4 py-3.5 items-center border-b border-gray-50 hover:bg-blue-50/30 transition-colors bg-gradient-to-r from-yellow-50/30 to-transparent">
                                    <div class="flex justify-center relative">
                                        <i class="ph-fill ph-crown text-[26px] rank-crown-1 absolute -top-[8px]"></i>
                                        <span class="text-white font-extrabold text-[12px] relative z-10 font-mono">1</span>
                                    </div>
                                    <div class="text-left font-extrabold text-[13px] text-gray-800 truncate">鲁梦妍</div>
                                    <div class="text-right font-mono font-bold text-[13px] text-gray-600">2450</div>
                                    <div class="text-right font-mono font-black text-[15px] text-gray-900">1890</div>
                                    <div class="text-right font-mono text-[13px] text-red-400">120</div>
                                    <div class="text-right font-mono text-[13px] text-gray-400">440</div>
                                    <div class="text-right font-mono font-bold text-[12px] text-[#10B981]">+164</div>
                                    <div class="text-right font-mono text-[12px] text-gray-400 pr-1">0</div>
                                </div>
                                <div class="rank-grid px-4 py-3.5 items-center border-b border-gray-50 hover:bg-blue-50/30 transition-colors bg-gradient-to-r from-gray-50/50 to-transparent">
                                    <div class="flex justify-center relative">
                                        <i class="ph-fill ph-crown text-[26px] rank-crown-2 absolute -top-[8px]"></i>
                                        <span class="text-white font-extrabold text-[12px] relative z-10 font-mono">2</span>
                                    </div>
                                    <div class="text-left font-extrabold text-[13px] text-gray-800 truncate">李官蓬</div>
                                    <div class="text-right font-mono font-bold text-[13px] text-gray-600">1800</div>
                                    <div class="text-right font-mono font-black text-[15px] text-gray-900">1420</div>
                                    <div class="text-right font-mono text-[13px] text-red-400">80</div>
                                    <div class="text-right font-mono text-[13px] text-gray-400">300</div>
                                    <div class="text-right font-mono font-bold text-[12px] text-[#10B981]">+100</div>
